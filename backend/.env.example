# Copy file nay thanh ".env" (hoac set truc tiep bien moi truong) khi chay o may local KHONG dung Codespaces.
# Trong GitHub Codespaces, cac bien nay da duoc set san boi docker-compose, KHONG can file .env.

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/petcare_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=petcare_password
SERVER_PORT=8080
