{
  "name": "PetCare System (Spring Boot + MySQL + Vite React)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint"
      ]
    }
  },

  // 8080: backend Spring Boot | 3306: MySQL | 5173: Vite dev server (frontend)
  "forwardPorts": [8080, 3306, 5173],
  "portsAttributes": {
    "8080": { "label": "Backend API (Spring Boot)", "onAutoForward": "notify" },
    "5173": { "label": "Frontend (Vite dev server)", "onAutoForward": "openBrowser" }
  },

  "postCreateCommand": "echo 'Doi MySQL container san sang...' && sleep 10 && mysql -h localhost -uroot -ppetcare_password -e 'SELECT 1' petcare_db && echo 'MySQL da san sang!'"
}
